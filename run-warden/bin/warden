#!/usr/bin/env sh
set -eu

warden_fail() { printf 'warden: %s\n' "$*" >&2; exit 1; }
warden_require_home() {
  [ -n "${HOME:-}" ] || warden_fail "HOME is required so Warden can resolve default paths. Set HOME, then rerun warden."
}

warden_require_home

WARDEN_BIN=$0
case "$WARDEN_BIN" in */*) RUN_WARDEN_DIR=${WARDEN_BIN%/*} ;; *) RUN_WARDEN_DIR=. ;; esac
RUN_WARDEN_ROOT=$(cd "$RUN_WARDEN_DIR/.." && pwd -P)
WARDEN_HOME=${WARDEN_HOME:-$(cd "$RUN_WARDEN_ROOT/.." && pwd -P)}
export WARDEN_HOME RUN_WARDEN_ROOT

. "$RUN_WARDEN_ROOT/lib/welcome.sh"
. "$RUN_WARDEN_ROOT/lib/doctor.sh"
. "$RUN_WARDEN_ROOT/lib/shell-integration.sh"
. "$RUN_WARDEN_ROOT/lib/pi-agents.sh"

usage() {
  cat <<'EOF'
usage: warden [command]

commands:
  welcome              print welcome and next steps
  doctor               run readiness checks
  agents new [NAME]          create isolated Pi agent environment
  agents set NAME cwd DIR    set agent launch working directory
  agents unset NAME cwd      unset agent launch working directory
  agents show NAME [--json]  show agent paths and settings
  agents list [--json]       list agent environments
  pi NAME [ARGS...]          run Pi inside an isolated agent environment
  shell status         show bash/zsh/fish integration status
  shell install        install selected shell integration after consent
  shell remove         remove guarded shell integration blocks
  shell snippet SHELL  print manual snippet for bash, zsh, or fish
  help                 show this help
EOF
}

command_name=${1:-welcome}
if [ $# -gt 0 ]; then shift; fi

case "$command_name" in
  welcome) warden_welcome ;;
  doctor) warden_doctor ;;
  pi) warden_pi "$@" ;;
  agents)
    subcommand=${1:-}
    if [ $# -gt 0 ]; then shift; fi
    case "$subcommand" in
      new) warden_agents_new "$@" ;;
      set) warden_agents_set "$@" ;;
      unset) warden_agents_unset "$@" ;;
      show) warden_agents_show "$@" ;;
      list) warden_agents_list "$@" ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  shell)
    subcommand=${1:-status}
    if [ $# -gt 0 ]; then shift; fi
    case "$subcommand" in
      status) warden_shell_status ;;
      install) warden_shell_install ;;
      remove) warden_shell_remove ;;
      snippet) warden_shell_snippet "${1:-}" ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  help|-h|--help) usage ;;
  *) printf '%s\n' "warden: unknown command: $command_name" >&2; usage >&2; exit 2 ;;
esac
