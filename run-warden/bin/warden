#!/usr/bin/env sh
set -eu

warden_fail() { printf 'warden: %s\n' "$*" >&2; exit 1; }
warden_require_home() {
  [ -n "${HOME:-}" ] || warden_fail "HOME is required so Warden can resolve default paths. Set HOME, then rerun warden."
}

warden_require_home

WARDEN_BIN=$0
case "$WARDEN_BIN" in */*) RUN_WARDEN_DIR=${WARDEN_BIN%/*} ;; *) RUN_WARDEN_DIR=. ;; esac
RUN_WARDEN_ROOT=$(cd "$RUN_WARDEN_DIR/.." && pwd -P)
WARDEN_HOME=${WARDEN_HOME:-$(cd "$RUN_WARDEN_ROOT/.." && pwd -P)}
export WARDEN_HOME RUN_WARDEN_ROOT

. "$RUN_WARDEN_ROOT/lib/welcome.sh"
. "$RUN_WARDEN_ROOT/lib/doctor.sh"
. "$RUN_WARDEN_ROOT/lib/shell-integration.sh"
. "$RUN_WARDEN_ROOT/lib/pi-agents.sh"
. "$RUN_WARDEN_ROOT/lib/worktree.sh"

usage() {
  cat <<'EOF'
usage: warden [command]

commands:
  welcome                    print welcome and next steps
  help                       show this help
  doctor                     run readiness checks
  shell status               show bash/zsh/fish integration status
  shell install              install selected shell integration after consent
  shell remove               remove guarded shell integration blocks
  shell init bash            print manual bash integration snippet
  shell init zsh             print manual zsh integration snippet
  shell init fish            print manual fish integration snippet
  agents new [NAME]          create isolated Pi agent environment
  agents list [--json]       list agent environments
  agents NAME update-pi      update Warden-managed Pi runtime
  agents NAME cwd DIR        set agent launch working directory
  agents NAME show [--json]  show agent paths and settings
  pi NAME [ARGS...]          run Pi inside isolated agent environment
  worktree AGENT             choose existing Git worktree for agent Pi launch
  @NAME [ARGS...]            run Pi inside isolated agent environment
EOF
}

command_name=${1:-welcome}
if [ $# -gt 0 ]; then shift; fi

case "$command_name" in
  welcome) warden_welcome ;;
  help|-h|--help) usage ;;
  doctor) warden_doctor ;;
  pi) warden_pi "$@" ;;
  worktree) warden_worktree "$@" ;;
  @*)
    agent_name=${command_name#@}
    warden_pi "$agent_name" "$@"
    ;;
  agents)
    subcommand=${1:-}
    if [ $# -gt 0 ]; then shift; fi
    case "$subcommand" in
      new) warden_agents_new "$@" ;;
      list) warden_agents_list "$@" ;;
      "") usage >&2; exit 2 ;;
      *)
        name=$subcommand
        verb=${1:-}
        if [ $# -gt 0 ]; then shift; fi
        case "$verb" in
          update-pi) warden_agents_update "$name" "$@" ;;
          cwd) warden_agents_set "$name" "$@" ;;
          show) warden_agents_show "$name" "$@" ;;
          *) usage >&2; exit 2 ;;
        esac
        ;;
    esac
    ;;
  shell)
    subcommand=${1:-status}
    if [ $# -gt 0 ]; then shift; fi
    case "$subcommand" in
      status) warden_shell_status ;;
      install) warden_shell_install ;;
      remove) warden_shell_remove ;;
      init) warden_shell_init "${1:-}" ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  *) printf '%s\n' "warden: unknown command: $command_name" >&2; usage >&2; exit 2 ;;
esac
