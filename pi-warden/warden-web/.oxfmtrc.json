{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "package-lock.json",
    "**/*.md",
    "**/*.yaml",
    "**/*.yml",
    "**/*.toml"
  ]
}
