    "context"
  ],
  "author": "nekwebdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nekwebdev/warden.git",
    "directory": "pi-warden/warden-flow"
  },
  "homepage": "https://github.com/nekwebdev/warden#readme",
  "bugs": {
    "url": "https://github.com/nekwebdev/warden/issues"
  },
  "publishConfig": {
